{
  "name": "sqliteeditor",
  "displayName": "sqlite editor by nqhuy",
  "description": "A powerful and lightweight SQLite extension for Visual Studio Code.",
  "version": "0.0.4",
  "icon": "images/sqlite.png",
  "publisher": "nguyenquochuy",
  "repository": {
    "type": "git",
    "url": "https://github.com/huy-2k2/sqlite_editor"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "browser": "./dist/web/extension.js",
  "contributes": {
    "customEditors": [
      {
        "viewType": "sqliteeditor",
        "displayName": "sqlite editor",
        "selector": [
          {
            "filenamePattern": "*.db"
          },
          {
            "filenamePattern": "*.sqlite"
          }
        ]
      }
    ]
  },
  "scripts": {
    "test": "npm run pre && vscode-test-web --browserType=chromium --extensionDevelopmentPath=. --extensionTestsPath=dist/web/test/suite/index.js",
    "pretest": "npm run pre && npm run compile-web",
    "vscode:prepublish": "npm run pre && npm run package-web",
    "compile-web": "npm run pre && webpack",
    "watch-web": "npm run pre && webpack --watch",
    "package-web": "npm run pre && webpack --mode production --devtool hidden-source-map",
    "lint": "npm run pre && eslint src",
    "run-in-browser": "vscode-test-web --browserType=chromium --extensionDevelopmentPath=. sample_databases",
    "pre": "copy customlibrary\\vscode-test-web\\workbench.html node_modules\\@vscode\\test-web\\views\\workbench.html && copy customlibrary\\vscode-test-web\\workbench-esm.html node_modules\\@vscode\\test-web\\views\\workbench-esm.html"
  },
  "devDependencies": {
    "@mui/x-data-grid-generator": "^8.27.1",
    "@types/assert": "^1.5.11",
    "@types/mocha": "^10.0.10",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/vscode": "^1.85.0",
    "@types/webpack-env": "^1.18.8",
    "assert": "^2.1.0",
    "css-loader": "^7.1.3",
    "eslint": "^9.39.2",
    "mocha": "^11.7.5",
    "patch-package": "^8.0.1",
    "postinstall-postinstall": "^2.1.0",
    "process": "^0.11.10",
    "style-loader": "^4.0.0",
    "ts-loader": "^9.5.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0",
    "webpack": "^5.104.1",
    "webpack-cli": "^6.0.1"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@monaco-editor/react": "^4.7.0",
    "@mui/material": "^7.3.8",
    "@mui/x-data-grid": "^8.27.1",
    "@vscode/test-web": "0.0.79",
    "@xyflow/react": "^12.10.2",
    "copy-webpack-plugin": "^13.0.1",
    "mermaid": "^11.12.3",
    "monaco-editor": "^0.55.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-grid-layout": "^2.2.2",
    "react-pro-sidebar": "^1.1.0",
    "react-spinners": "^0.17.0",
    "react-toastify": "^11.0.5",
    "sql.js": "^1.14.0"
  }
}
